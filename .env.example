# ----------------------------
# Backend
# ----------------------------
DB_URL=jdbc:mysql://localhost:3306/smartroute?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USER=root
DB_PASSWORD=root

# IMPORTANT: must be >= 32 bytes for HS256
JWT_SECRET_CHANGE_ME=change-me-change-me-change-me-change-me-123456
JWT_ISSUER=smartroute
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Cookie security (set to true in production behind HTTPS)
SMARTRoute_COOKIE_SECURE=false

# SMTP email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASSWORD=example
smartroute.mail.from=no-reply@localhost

# Frontend base for reset password links
SMARTRoute_FRONTEND_RESET_URL=http://localhost:5173/reset-password
smartroute.frontend.resetPasswordBaseUrl=http://localhost:5173/reset-password

# TomTom / Mapbox placeholders
TOMTOM_API_KEY=
MAPBOX_ACCESS_TOKEN=

# CORS
SMARTRoute_CORS_ORIGIN=http://localhost:5173

# ----------------------------
# Frontend
# ----------------------------
VITE_API_URL=http://localhost:8080

